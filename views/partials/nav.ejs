<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PhotographyRS</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="site-nav">
        <a class="site-nav-brand" href="/">PhotographyRS</a>

        <div class="site-nav-links">
            <% if (user) { %>
                <a class="site-nav-link" href="/dashboard">Dashboard</a>
                <a class="site-nav-link" href="/gallery">Gallery</a>
                <a class="site-nav-link" href="/Bookings">Bookings</a>
                <a class="site-nav-link" href="/Bookings/new">New Booking</a>
                <a class="site-nav-link" href="/questions">FAQ</a>



                <form
                    class="site-nav-form"
                    action="/auth/sign-out?_method=DELETE"
                    method="POST"
                >
                    <button class="site-nav-button" type="submit">
                        Sign Out
                    </button>
                </form>
            <% } else { %>
                <a class="site-nav-link" href="/auth/sign-up">Sign Up</a>
                <a class="site-nav-link" href="/auth/sign-in">Sign In</a>
            <% } %>
        </div>
    </nav>
