<%- include('./partials/nav') %>
<title>All Bookings</title>

<div class="show-booking-card d-flex flex-wrap justify-content-center gap-4 w-100 max-w-1200 mx-auto">
  
    <% if(allBookings && allBookings.length>0){ %>
  <% allBookings.forEach(function(item){ %>

        <div class="card border-0 shadow-sm rounded-4 p-4 m-0 flex-grow-1" style="width: 100%; max-width: 420px; background-color: #ffffff;">
      
      <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
          <h4 class="fw-bold mb-1 text-dark"><%= item.name.toUpperCase() %></h4>
          <div class="d-flex align-items-center gap-2 text-muted small">
            <span class="rounded-circle bg-warning d-inline-block" style="width: 10px; height: 10px;"></span>
            <span>Package: <%= item.package %></span>
          </div>
        </div>
        
        <span class="badge rounded-pill bg-success text-white px-3 py-2 fw-medium d-flex align-items-center gap-1 fs-6">
          <i class="bi bi-check-lg"></i> Booked
        </span>
      </div>

      <h6 class="fw-bold text-dark mb-3">Booking details</h6>

      <div class="bg-body-tertiary rounded-4 p-3 mb-3">
        <div class="row align-items-center g-2">
          
            <div class="d-flex align-items-center gap-2 text-secondary small">
              <i class="bi bi-clock text-secondary"></i>
              <span>Booking Date</span>
            </div>
            <div class="d-flex align-items-center gap-2 mb-2 text-dark small fw-medium">
              <i class="bi bi-calendar4 text-secondary"></i>
              <span><%= item.date.toLocaleDateString('en-US',{weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'}) %></span>
            </div>

        </div>
      </div>

      <a class="submit text-center" id="show-booking-btn" href="/bookings/<%= item._id %>">Show Booking</a>

    </div>
    
  <% }) } else {%>
    <div class="text-center p-5">
    <h3 class="text-white-50 fw-bold">No bookings found</h3>
  </div>
<% } %>

</div>